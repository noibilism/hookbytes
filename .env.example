APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# API Authentication
# API keys are generated per user and used for authentication
# Use: php artisan apikey:generate --email=user@example.com
# Headers: Authorization: Bearer {api_key} OR X-API-Key: {api_key}

# Webhook Configuration
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=60
WEBHOOK_RETRY_MULTIPLIER=2
WEBHOOK_MAX_RETRY_DELAY=3600

# Webhook Security
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
WEBHOOK_TIMESTAMP_HEADER=X-Webhook-Timestamp
WEBHOOK_SIGNATURE_ALGORITHM=sha256
WEBHOOK_TIMESTAMP_TOLERANCE=300
WEBHOOK_VERIFY_SSL=true

# Rate Limiting
WEBHOOK_RATE_LIMITING_ENABLED=true
WEBHOOK_RATE_LIMIT_ATTEMPTS=60
WEBHOOK_RATE_LIMIT_DECAY=1
WEBHOOK_RATE_LIMIT_PER_ENDPOINT=true

# Idempotency
WEBHOOK_IDEMPOTENCY_ENABLED=true
WEBHOOK_IDEMPOTENCY_HEADER=X-Idempotency-Key
WEBHOOK_IDEMPOTENCY_TTL=86400

# Dead Letter Queue
WEBHOOK_DEAD_LETTER_ENABLED=true
WEBHOOK_DEAD_LETTER_MAX_FAILURES=5
WEBHOOK_DEAD_LETTER_RETENTION_DAYS=30

# Logging
WEBHOOK_LOGGING_ENABLED=true
WEBHOOK_LOG_REQUESTS=true
WEBHOOK_LOG_RESPONSES=true
WEBHOOK_LOG_FAILURES=true
WEBHOOK_LOG_RETENTION_DAYS=90

# Data Redaction
WEBHOOK_REDACTION_ENABLED=true

# Queue Configuration
WEBHOOK_QUEUE_CONNECTION=redis
WEBHOOK_QUEUE_NAME=webhooks
WEBHOOK_HIGH_PRIORITY_QUEUE=webhooks-high
WEBHOOK_FAILED_QUEUE=webhooks-failed

# HTTP Client
WEBHOOK_USER_AGENT="Laravel-Webhook-Service/1.0"
WEBHOOK_CONNECT_TIMEOUT=10
WEBHOOK_READ_TIMEOUT=30
WEBHOOK_FOLLOW_REDIRECTS=false
WEBHOOK_MAX_REDIRECTS=3

# Metrics
WEBHOOK_METRICS_ENABLED=true
WEBHOOK_DAILY_AGGREGATION=true
WEBHOOK_METRICS_RETENTION_DAYS=365

# Dashboard
WEBHOOK_DASHBOARD_ENABLED=true
WEBHOOK_DASHBOARD_PREFIX=dashboard
WEBHOOK_DASHBOARD_PER_PAGE=25
WEBHOOK_DASHBOARD_MAX_PER_PAGE=100
